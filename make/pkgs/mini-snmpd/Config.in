config FREETZ_PACKAGE_MINI_SNMPD
	bool "mini-snmpd 1.7/2.0 (binary only)"
	depends on !(FREETZ_TARGET_UCLIBC_0_9_28 || FREETZ_TARGET_UCLIBC_0_9_29)
	default n
	help
		This program is an SNMP server for "embedded systems".
		The advantage in comparison to other products is the
		low usage of system resources.

if FREETZ_PACKAGE_MINI_SNMPD

	choice
		prompt "Version"
			default FREETZ_PACKAGE_MINI_SNMPD_VERSION_CURRENT

		config FREETZ_PACKAGE_MINI_SNMPD_VERSION_ABANDON
			bool "1.7"
			depends on FREETZ_KERNEL_VERSION_2

		config FREETZ_PACKAGE_MINI_SNMPD_VERSION_CURRENT
			bool "2.0"
			depends on !FREETZ_KERNEL_VERSION_2
			select FREETZ_LIB_libconfuse

	endchoice

endif # FREETZ_PACKAGE_MINI_SNMPD

